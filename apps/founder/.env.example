# Copy to .env.local for local development.
# Points the web app at the FastAPI backend. For local dev against a laptop-hosted
# backend use http://localhost:8000; the deployed backend lives at the Render URL
# below (already set in .env.production for production builds).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: https://leadpilot-backend-perc.onrender.com
